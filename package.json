{
  "name": "2026-design-trends",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "2026 디자인 트렌드를 한국어로 큐레이션하고 라이브로 체험하는 사이트",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "export:html": "npm run build && node scripts/copy-html-export.mjs",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:e2e": "playwright test",
    "verify": "npm run lint && npm run test:run && npm run build",
    "lint": "eslint ."
  },
  "dependencies": {
    "framer-motion": "^12.9.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@playwright/test": "^1.52.0",
    "@types/node": "^22.15.3",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "eslint": "^9.25.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "jsdom": "^26.1.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.30.1",
    "vite": "^6.3.5",
    "vitest": "^3.1.2"
  }
}
